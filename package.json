{
  "name": "dnd_card_game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Wi-Fi LAN host-authoritative turn-based card game prototype.",
  "scripts": {
    "dev:host": "tsx src/host/runHost.ts",
    "dev:client": "tsx src/client/runClient.ts",
    "dev:worker": "wrangler dev",
    "dev:pages": "vite web --host 0.0.0.0",
    "build": "npm run build:node && npm run build:worker && npm run build:pages",
    "build:node": "tsc -p tsconfig.json",
    "build:worker": "tsc --noEmit -p worker/tsconfig.json",
    "build:pages": "vite build web",
    "deploy:worker": "wrangler deploy",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260604.0",
    "@types/node": "^20.14.10",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.4.11",
    "wrangler": "^4.40.2",
    "vitest": "^1.6.0"
  }
}
